{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",

    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],

    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,

    "types": [
      "vite/client",
      "google.maps"
    ]
  },

  "include": [
    "src",
    "vite.config.ts"
  ]
}